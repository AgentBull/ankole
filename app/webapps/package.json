    "i18next": "26.3.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-helmet-async": "3.0.0",
    "react-i18next": "17.0.8",
    "react-router": "8.0.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/bun": "latest",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",

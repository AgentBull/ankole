{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "bun.lock",
    "tsconfig.base.json",
    "turbo.json",
    ".oxlintrc.json",
    ".oxfmtrc.json",
    "bunfig.toml"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "common/**",
        "auth/**",
        "console/**",
        "entrypoints/**",
        "setup/**",
        "app/**",
        "pages/**",
        "server/**",
        "scripts/**",
        "lib/**",
        "config/**",
        "assets/**",
        "priv/**",
        "public/**",
        "package.json",
        "mix.exs",
        "mix.lock",
        "tsconfig*.json",
        "vite.config.*",
        "drizzle.config.*",
        "*.config.*",
        ".env*"
      ],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
        ".output/**",
        "priv/static/assets/**",
        "priv/static/cache_manifest.json"
      ]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "inputs": [
        "src/**",
        "common/**",
        "auth/**",
        "console/**",
        "entrypoints/**",
        "setup/**",
        "app/**",
        "tests/**",
        "test/**",
        "__tests__/**",
        "lib/**",
        "config/**",
        "assets/**",
        "priv/**",
        "migrations/**",
        "prisma/**",
        "drizzle/**",
        "package.json",
        "mix.exs",
        "mix.lock",
        "tsconfig*.json",
        "bunfig.toml",
        ".env*"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["type-check", "^type-check"],
      "inputs": [
        "src/**",
        "common/**",
        "auth/**",
        "console/**",
        "entrypoints/**",
        "setup/**",
        "app/**",
        "tests/**",
        "test/**",
        "__tests__/**",
        "fixtures/**",
        "lib/**",
        "config/**",
        "assets/**",
        "priv/**",
        "package.json",
        "mix.exs",
        "mix.lock",
        "tsconfig*.json",
        "bunfig.toml",
        ".env*"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "inputs": [
        "src/**",
        "common/**",
        "auth/**",
        "console/**",
        "entrypoints/**",
        "setup/**",
        "app/**",
        "tests/**",
        "test/**",
        "__tests__/**",
        "scripts/**",
        "lib/**",
        "config/**",
        "assets/**",
        "priv/**",
        "package.json",
        "mix.exs",
        "mix.lock",
        ".formatter.exs",
        "tsconfig*.json",
        ".env*"
      ]
    },
    "fmt": {
      "cache": false,
      "inputs": [
        "src/**",
        "common/**",
        "auth/**",
        "console/**",
        "entrypoints/**",
        "setup/**",
        "app/**",
        "tests/**",
        "test/**",
        "__tests__/**",
        "scripts/**",
        "lib/**",
        "config/**",
        "assets/**",
        "priv/**",
        "package.json",
        "mix.exs",
        "mix.lock",
        ".formatter.exs",
        "tsconfig*.json"
      ],
      "outputs": []
    },
    "fmt:check": {
      "inputs": [
        "src/**",
        "common/**",
        "auth/**",
        "console/**",
        "entrypoints/**",
        "setup/**",
        "app/**",
        "tests/**",
        "test/**",
        "__tests__/**",
        "scripts/**",
        "lib/**",
        "config/**",
        "assets/**",
        "priv/**",
        "package.json",
        "mix.exs",
        "mix.lock",
        ".formatter.exs",
        "tsconfig*.json"
      ],
      "outputs": []
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}

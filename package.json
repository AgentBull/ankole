    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "turbo": "^2.9.16"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260602.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0"
  },
  "packageManager": "bun@1.3.14"
}

{
  "name": "@agentbull/bullx-monorepo",
  "private": true,
  "workspaces": [
    "app",
    "packages/*",
    "plugin/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "kit": "bun tools/devkit/src/main.ts",
    "dev": "cd app && bun run dev",
    "workspace:update": "bun run kit g code-workspace",
    "services:start": "bun run kit external-services start",
    "services:stop": "bun run kit external-services stop",
    "services:status": "bun run kit external-services status",
    "db:create": "bun run kit app-db create",
    "db:rebuild": "bun run kit app-db rebuild",
    "db:migrate:gen": "bun run --elide-lines=0 --filter @agentbull/bullx-agent migrate:gen",
    "db:migrate:up": "bun run --elide-lines=0 --filter @agentbull/bullx-agent migrate:local",
    "lint": "oxlint && turbo run lint",
    "lint:fix": "oxlint --fix",
    "type-check": "turbo run type-check",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "test": "turbo run test"
  },
  "dependencies": {
    "turbo": "^2.9.16"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260607.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "pino-pretty": "^13.1.3"
  },
  "packageManager": "bun@1.3.14"
}

{
  "name": "@agentbull/ankole",
  "private": true,
  "workspaces": [
    "app/*",
    "libs/*",
    "plugin/*",
    "internals/plugins/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "kit": "bun tools/devkit/src/main.ts",
    "workspace:update": "bun run kit g code-workspace",
    "services:start": "bun run kit external-services start",
    "services:stop": "bun run kit external-services stop",
    "services:status": "bun run kit external-services status",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "oxlint && turbo run lint",
    "lint:fix": "oxlint --fix",
    "type-check": "turbo run type-check",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "agent-computer": "bun run --filter @ankole/agent-computer",
    "agent-computer:test": "bun run --filter @ankole/agent-computer test",
    "agent-computer:type-check": "bun run --filter @ankole/agent-computer type-check",
    "agent-computer:e2e": "bun run --filter @ankole/control-plane e2e:actor-runtime-worker",
    "control-plane": "bun run --filter @ankole/control-plane",
    "control-plane:setup": "bun run --filter @ankole/control-plane setup",
    "control-plane:dev": "bun run --filter @ankole/control-plane dev",
    "control-plane:test": "bun run --filter @ankole/control-plane test",
    "control-plane:routes": "bun run --filter @ankole/control-plane routes",
    "webapps": "bun run --filter @ankole/webapps",
    "webapps:dev": "bun run --filter @ankole/webapps dev",
    "webapps:build": "bun run --filter @ankole/webapps build",
    "webapps:type-check": "bun run --filter @ankole/webapps type-check",
    "uikit": "bun run --filter @ankole/uikit",
    "uikit:type-check": "bun run --filter @ankole/uikit type-check",
    "feishu-openapi": "bun run --filter @ankole/feishu-openapi",
    "feishu-openapi:test": "bun run --filter @ankole/feishu-openapi test",
    "analyze": "bun run kit analyze all",
    "analyze:smells": "bun run kit analyze smells",
    "analyze:unused": "bun run kit analyze unused",
    "analyze:duplicates": "bun run kit analyze duplicates",
    "analyze:cycles": "bun run kit analyze cycles",
    "analyze:topology": "bun run kit analyze topology"
  },
  "dependencies": {
    "turbo": "^2.10.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260630.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "pino-pretty": "^13.1.3"
  },
  "packageManager": "bun@1.3.14"
}

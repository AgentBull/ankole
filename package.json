{
  "packageManager": "bun@1.3.13",
  "scripts": {
    "setup": "mix deps.get && mix ecto.setup && bun install && mix assets.build",
    "dev": "iex -S mix phx.server",
    "rsbuild:dev": "bun --bun rsbuild dev --log-level warn",
    "build": "bun --bun rsbuild build",
    "fmt": "mix format && cargo fmt --all && bun --bun biome format webui/src",
    "fmt:check": "mix format --check-formatted && cargo fmt --all --check",
    "db:reset": "mix ecto.reset",
    "db:migrate": "mix ecto.migrate",
    "db:rollback": "mix ecto.rollback",
    "db:create": "mix ecto.create",
    "db:seed": "mix run priv/repo/seeds.exs",
    "db:drop": "mix ecto.drop",
    "openapi:spec": "mix openapi.spec.json --spec BullXWeb.ApiSpec --pretty=true priv/openapi/internal-api.json",
    "openapi:client": "openapi-ts",
    "gen:api": "bun run openapi:spec && bun run openapi:client",
    "lint:js": "bun --bun biome check webui/src",
    "lint": "bun --bun turbo run lint:js fmt:check --output-logs=new-only",
    "test": "bun test webui/src",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:elixir": "MIX_ENV=test mix test",
    "compile": "MIX_ENV=test mix compile --warnings-as-errors",
    "i18n": "MIX_ENV=test mix i18n.check",
    "deps:unused": "mix deps.unlock --unused",
    "precommit": "bun --bun turbo run lint:js test fmt:check deps:unused compile i18n test:elixir --output-logs=new-only"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@inertiajs/react": "^3.2.0",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-router": "^1.170.7",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.2.0",
    "input-otp": "^1.4.2",
    "json-edit-react": "^1.30.1",
    "messageformat": "^4.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@happy-dom/global-registrator": "^20.9.0",
    "@hey-api/openapi-ts": "^0.97.2",
    "@iarna/toml": "^2.2.5",
    "@rsbuild/core": "^2.0.7",
    "@rsbuild/plugin-react": "^2.0.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "happy-dom": "^20.8.9",
    "storybook": "^10.4.0",
    "storybook-react-rsbuild": "^3.3.4",
    "tailwindcss": "^4.3.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3"
  }
}

{
  "name": "@agentbull/bullx-monorepo",
  "private": true,
  "workspaces": [
    "app",
    "packages/*",
    "plugin/*"
  ],
  "type": "module",
  "scripts": {
    "lint": "oxlint && turbo run lint",

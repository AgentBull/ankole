{
  "name": "@agentbull/bullx-computer",
  "version": "0.1.0",
  "description": "Lightweight LLM computer worker for trusted BullX environments: Rust worker daemon (bullx-computerd) + Vercel-like TypeScript SDK.",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": "./client-sdk/index.ts"
  },
  "scripts": {
    "type-check": "tsgo -p tsconfig.json --noEmit",
    "lint": "cargo clippy --all-targets",
    "fmt": "oxfmt && cargo fmt",
    "fmt:check": "oxfmt --check && cargo fmt --check",
    "test": "bun test",
    "build:daemon": "cargo build --release --bin bullx-computerd",
    "test:daemon": "cargo test"
  }
}

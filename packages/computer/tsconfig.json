{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "types": ["bun"],
    "paths": {
      "@/*": ["./client-sdk/*"]
    }
  },
  "include": ["client-sdk/**/*.ts"],
  "exclude": ["node_modules", "target"]
}

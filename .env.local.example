# Copy this file to .env.local (gitignored) for personal overrides that take
# precedence over .env.dev in dev mode.
# Use .env.dev / .env.test (both committed) for shared team environment
# variables. Do not rely on code-level defaults for required runtime config.

# Example contents:
# DATABASE_URL=<required>
# Devbox uses port 6379 for dev Redis and 6380 for test Redis.
# BULLX_CACHE_REDIS_URL=redis://localhost:6379
# BULLX_SECRET_BASE=<required>
# PORT=4001
# VITE_PORT=5174

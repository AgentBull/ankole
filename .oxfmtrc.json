{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 120,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "none",
  "semi": false,
  "arrowParens": "avoid",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/db/meta/*.json",
    "packages/native-addons/index.d.ts",
    "packages/native-addons/index.js",
    "packages/native-addons/main.js",
    "**/*.toml",
    "**/*.md",
    "**/*.mdx",
    "**/*.yaml",
    "**/*.yml"
  ]
}
